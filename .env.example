# WooCommerce REST API
WC_URL=https://your-store.com
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Authorize.net server-side credentials (never expose these publicly)
#
# Supported env var naming (pick one set):
# - AUTHORIZE_NET_* (new)
# - AUTHNET_* (matches your current .env.local)
AUTHORIZE_NET_API_LOGIN_ID=your_api_login_id
AUTHORIZE_NET_TRANSACTION_KEY=your_transaction_key
AUTHORIZE_NET_SIGNATURE_KEY=your_signature_key_optional_for_webhooks

# Authorize.net env switch: sandbox | production
AUTHORIZE_NET_ENV=sandbox

# Accept.js public credentials for tokenization (client-side)
NEXT_PUBLIC_AUTHORIZE_NET_API_LOGIN_ID=your_api_login_id
NEXT_PUBLIC_AUTHORIZE_NET_CLIENT_KEY=your_public_client_key
